# this will cause the node package "config" to load configuration data 
# from the directory ./src/arbitrary/config (instead of ./config)
NODE_CONFIG_DIR=src/arbitrary/config

# this will eventually exist as both an environment variable (just like 
# NODE_CONFIG_DIR, above) as well as a configuration value (via the node package "config")
SECRET_MESSAGE_FROM_DOTENV_FILE=Be sure to drink your Ovaltine
